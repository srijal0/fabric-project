# Copy this file to .env and adjust values as needed.
# .env is gitignored — never commit real secrets or machine-specific paths.

# Database connection string. SQLite for local dev; swap for Postgres in production, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/fabrics
DATABASE_URL=sqlite:///./fabrics.db

# Comma-separated list of origins allowed to call this API.
# Use * only for local development.
CORS_ORIGINS=*